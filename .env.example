# =============================================================================
# Supereye production environment — copy to `.env` on your VPS at /opt/supereye
# NEVER commit the real `.env` file.
# =============================================================================

# ─── Domain & Docker ─────────────────────────────────────────────────────────
DOMAIN=supereye.dev
ACME_EMAIL=you@supereye.dev
DOCKER_IMAGE=ghcr.io/satyasootar/supereye:latest

# ─── PostgreSQL (Docker internal) ─────────────────────────────────────────────
POSTGRES_DB=supereye
POSTGRES_USER=supereye
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# App connects via docker-compose (do not change host unless you use external DB)
DATABASE_URL=postgresql://supereye:change-me-to-a-long-random-password@postgres:5432/supereye

# ─── App URL (must match DOMAIN with https://) ────────────────────────────────
NEXT_PUBLIC_APP_URL=https://supereye.dev
NODE_ENV=production

# ─── NextAuth v5 (login) ─────────────────────────────────────────────────────
# Generate: npx auth secret
AUTH_SECRET=

# Google OAuth for user login (Google Cloud Console → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub OAuth App (Settings → Developer settings → OAuth Apps)
# Authorization callback URL: https://supereye.dev/api/corsair/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Corsair (integration tokens encryption) ─────────────────────────────────
# Generate once: openssl rand -base64 32
# WARNING: changing this breaks all connected integrations
CORSAIR_KEK=

# ─── Google Pub/Sub (Gmail push webhooks) ─────────────────────────────────────
# Full resource paths from Google Cloud Console
GMAIL_PUBSUB_TOPIC=projects/supereye-499110/topics/corsair-webhooks
GMAIL_PUBSUB_SUBSCRIPTION=projects/supereye-499110/subscriptions/corsair-webhooks-push

# ─── Webhooks (Google Calendar push verification) ────────────────────────────
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=

# ─── Cron (scheduled email sending) ─────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=

# ─── Resend (password reset emails) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Supereye <noreply@supereye.dev>

# ─── AI providers (at least one required) ────────────────────────────────────
# Leave unset to auto-select: OpenAI when OPENAI_API_KEY is set, otherwise Mistral.
# AI_PROVIDER=openai without OPENAI_API_KEY falls back to Mistral.
# AI_PROVIDER=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
TRIAGE_MODEL=

# ─── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated emails that receive super_admin on sign-in (also accepts ADMIN_EMAIL)
SUPER_ADMIN_EMAILS=you@supereye.dev
# ADMIN_EMAIL=you@supereye.dev

# ─── Optional ─────────────────────────────────────────────────────────────────
ALLOW_SIMULATED_BILLING=false
