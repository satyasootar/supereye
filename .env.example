# =============================================================================
# Supereye production environment — copy to `.env` on your VPS at /opt/supereye
# NEVER commit the real `.env` file.
# =============================================================================

# ─── Domain & Docker ─────────────────────────────────────────────────────────
DOMAIN=app.yourdomain.com
ACME_EMAIL=you@yourdomain.com
DOCKER_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/supereye:latest

# ─── PostgreSQL (Docker internal) ─────────────────────────────────────────────
POSTGRES_DB=supereye
POSTGRES_USER=supereye
POSTGRES_PASSWORD=change-me-to-a-long-random-password

# App connects via docker-compose (do not change host unless you use external DB)
DATABASE_URL=postgresql://supereye:change-me-to-a-long-random-password@postgres:5432/supereye

# ─── App URL (must match DOMAIN with https://) ────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.yourdomain.com
NODE_ENV=production

# ─── NextAuth v5 (login) ─────────────────────────────────────────────────────
# Generate: npx auth secret
AUTH_SECRET=

# Google OAuth for user login (Google Cloud Console → Credentials)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Corsair (integration tokens encryption) ─────────────────────────────────
# Generate once: openssl rand -base64 32
# WARNING: changing this breaks all connected integrations
CORSAIR_KEK=

# ─── Google Pub/Sub (Gmail push webhooks) ─────────────────────────────────────
# Full resource paths from Google Cloud Console
GMAIL_PUBSUB_TOPIC=projects/YOUR_GCP_PROJECT/topics/supereye-gmail
GMAIL_PUBSUB_SUBSCRIPTION=projects/YOUR_GCP_PROJECT/subscriptions/supereye-gmail-push

# ─── Webhooks (Google Calendar push verification) ────────────────────────────
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=

# ─── Cron (scheduled email sending) ─────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=

# ─── Resend (password reset emails) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Supereye <noreply@yourdomain.com>

# ─── AI providers (at least one required) ────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
TRIAGE_MODEL=

# ─── Admin ───────────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAILS=you@yourdomain.com

# ─── Optional ─────────────────────────────────────────────────────────────────
ALLOW_SIMULATED_BILLING=false
