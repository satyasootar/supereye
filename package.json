    "corsair": "^0.1.76",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
