{
  "name": "supereye",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:keyboard": "npx tsx --test lib/keyboard/__tests__/keyboard.test.ts lib/keyboard/__tests__/validate-overrides.test.ts",
